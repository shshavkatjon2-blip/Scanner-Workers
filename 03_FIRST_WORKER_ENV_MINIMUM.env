NODE_ENV=production
WORKER_MODE=scanner
SCANNER_WORKER_MODE=true
PAYMENT_SCANNER_ENABLED=true

SUPABASE_URL=PASTE_FROM_VIDIPAY_BACKEND_ENV
SUPABASE_SERVICE_ROLE_KEY=PASTE_FROM_VIDIPAY_BACKEND_ENV

TONAPI_BASE_URL=https://tonapi.io
TONAPI_KEY=PASTE_FROM_VIDIPAY_BACKEND_ENV

RATE_LIMIT_BACKEND=redis
REDIS_URL=PASTE_THE_SAME_REDIS_URL_FROM_VIDIPAY_BACKEND
REDIS_DEEP_CHECK_ENABLED=true
REDIS_SCANNER_LOCKS_ENABLED=true

PAYMENT_SCANNER_WORKER_ID=vidipay-scanner-000
PAYMENT_SCANNER_SHARD_COUNT=4
PAYMENT_SCANNER_SHARD_INDEX=0

PAYMENT_SCAN_INTERVAL_MS=3000
PAYMENT_SCAN_BATCH_SIZE=500
PAYMENT_SCAN_CONCURRENCY=32
TON_PAYMENT_MIN_RECEIVED=6.90
TON_PAYMENT_MAX_RECEIVED=7.05
