with wallet_capacity as (
  select
    count(*) filter (
      where coalesce(is_active, true) = true
        and assigned_to_telegram_id is null
    ) as available_wallets
  from public.payment_wallets
),
scanner_live as (
  select
    count(*) filter (where last_seen_at > now() - interval '30 seconds') as workers_alive,
    count(distinct shard_index) filter (where last_seen_at > now() - interval '30 seconds') as active_shards
  from public.payment_scanner_heartbeats
),
duplicates as (
  select count(*) as duplicate_groups
  from (
    select address
    from public.payment_wallets
    where address is not null
    group by address
    having count(*) > 1
  ) d
)
select 'wallet_capacity_1_5m_ready' as check_name, available_wallets >= 1500000 as ok, available_wallets::text as detail from wallet_capacity
union all
select 'scanner_workers_alive_min_4', workers_alive >= 4, workers_alive::text from scanner_live
union all
select 'scanner_active_shards_min_4', active_shards >= 4, active_shards::text from scanner_live
union all
select 'wallet_duplicate_groups_zero', duplicate_groups = 0, duplicate_groups::text from duplicates;
